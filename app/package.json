{
  "name": "sensatype-fonttool-ui",
  "private": true,
  "version": "0.1.22",
  "description": "Sensatype Font Tool — desain SVG/PDF glyph menjadi font OTF/TTF/WOFF",
  "author": "Sensatype Studio",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "electron electron/main.cjs",
    "electron:dev": "ELECTRON_RENDERER_URL=http://localhost:5173 electron electron/main.cjs",
    "dist": "npm run build && bash ../scripts/build-content.sh && electron-builder",
    "dist:mac": "npm run build && bash ../scripts/build-content.sh && electron-builder --mac",
    "dist:win": "npm run build && bash ../scripts/build-content.sh && electron-builder --win",
    "release": "npm run build && bash ../scripts/build-content.sh && electron-builder --publish always"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.544.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.0",
    "vite": "^7.1.0"
  },
  "build": {
    "appId": "com.sensatype.fonttool",
    "productName": "Sensatype Font Tool",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.cjs",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend-dist/sensatype-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../content",
        "to": "content",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sensatype",
        "repo": "Sensatype-Font-Tool-App"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.png",
      "identity": null
    },
    "dmg": {
      "title": "Sensatype Font Tool"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
